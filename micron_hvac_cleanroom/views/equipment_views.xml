<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_micron_equipment_tree" model="ir.ui.view">
        <field name="name">micron.equipment.list</field>
        <field name="model">micron.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="model_no"/>
                <field name="instrument_type"/>
                <field name="calibration_date"/>
                <field name="calibration_due_date"/>
                <field name="is_active"/>
            </list>
        </field>
    </record>

    <record id="view_micron_equipment_form" model="ir.ui.view">
        <field name="name">micron.equipment.form</field>
        <field name="model">micron.equipment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="model_no"/>
                            <field name="serial_number"/>
                        </group>
                        <group>
                            <field name="instrument_type"/>
                            <field name="calibration_date"/>
                            <field name="calibration_due_date"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_micron_equipment" model="ir.actions.act_window">
        <field name="name">Equipment</field>
        <field name="res_model">micron.equipment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_micron_equipment" name="Equipment" parent="menu_micron_master_data" action="action_micron_equipment" sequence="10"/>
</odoo>
