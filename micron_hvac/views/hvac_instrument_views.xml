<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- ═══ Instrument Registry ═══ -->
    <record id="view_hvac_instrument_list" model="ir.ui.view">
        <field name="name">hvac.instrument.list</field>
        <field name="model">hvac.instrument</field>
        <field name="arch" type="xml">
            <list string="Instrument Registry"
                  decoration-danger="calibration_status in ('overdue','not_calibrated')"
                  decoration-warning="calibration_status == 'due_soon'"
                  decoration-success="calibration_status == 'valid'">
                <field name="asset_code" string="Asset Code"/>
                <field name="name" string="Instrument Name"/>
                <field name="instrument_type"/>
                <field name="make"/>
                <field name="model_no"/>
                <field name="serial_no"/>
                <field name="last_calibration_date" string="Last Cal."/>
                <field name="next_calibration_date" string="Next Cal. Due"/>
                <field name="calibration_status" widget="badge"
                       decoration-success="calibration_status == 'valid'"
                       decoration-warning="calibration_status == 'due_soon'"
                       decoration-danger="calibration_status in ('overdue','not_calibrated')"/>
                <field name="latest_cert_no" string="Last Cert No."/>
                <field name="calibration_count" string="# Cals"/>
            </list>
        </field>
    </record>

    <record id="view_hvac_instrument_form" model="ir.ui.view">
        <field name="name">hvac.instrument.form</field>
        <field name="model">hvac.instrument</field>
        <field name="arch" type="xml">
            <form string="Instrument">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_calibrations" type="object"
                                class="oe_stat_button" icon="fa-certificate">
                            <field name="calibration_count" widget="statinfo" string="Calibrations"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Overdue" bg_color="bg-danger"
                            invisible="calibration_status not in ('overdue','not_calibrated')"/>
                    <widget name="web_ribbon" title="Due Soon" bg_color="bg-warning"
                            invisible="calibration_status != 'due_soon'"/>
                    <div class="oe_title">
                        <label class="o_form_label" for="name"/>
                        <h1><field name="name" placeholder="Instrument Name"/></h1>
                        <h2 class="text-muted"><field name="asset_code" placeholder="Asset Code"/></h2>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="instrument_type"/>
                            <field name="make"/>
                            <field name="model_no"/>
                            <field name="serial_no"/>
                            <field name="purchase_date"/>
                            <field name="location"/>
                        </group>
                        <group string="Specifications">
                            <field name="range_description" string="Measurement Range"/>
                            <field name="resolution"/>
                            <field name="accuracy_class"/>
                        </group>
                    </group>
                    <group string="Calibration Status">
                        <group>
                            <field name="calibration_interval" string="Cal. Interval (days)"/>
                            <field name="last_calibration_date"/>
                            <field name="next_calibration_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="calibration_status" readonly="1" widget="badge"
                                   decoration-success="calibration_status == 'valid'"
                                   decoration-warning="calibration_status == 'due_soon'"
                                   decoration-danger="calibration_status in ('overdue','not_calibrated')"/>
                            <field name="latest_cert_no" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Calibration History">
                            <field name="calibration_ids">
                                <list string="Calibration Records">
                                    <field name="name" string="Certificate No."/>
                                    <field name="calibration_date"/>
                                    <field name="valid_until"/>
                                    <field name="calibrated_by"/>
                                    <field name="result" widget="badge"
                                           decoration-success="result == 'pass'"
                                           decoration-warning="result == 'conditional'"
                                           decoration-danger="result == 'fail'"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-muted="state == 'expired'"/>
                                    <field name="error_found"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes about this instrument..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hvac_instrument_search" model="ir.ui.view">
        <field name="name">hvac.instrument.search</field>
        <field name="model">hvac.instrument</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="asset_code"/>
                <field name="serial_no"/>
                <filter name="valid" string="Valid Calibration" domain="[('calibration_status','=','valid')]"/>
                <filter name="due_soon" string="Due Soon" domain="[('calibration_status','=','due_soon')]"/>
                <filter name="overdue" string="Overdue" domain="[('calibration_status','in',['overdue','not_calibrated'])]"/>
                <group expand="0" string="Group By">
                    <filter name="by_type" string="Type" context="{'group_by':'instrument_type'}"/>
                    <filter name="by_status" string="Cal. Status" context="{'group_by':'calibration_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hvac_instrument" model="ir.actions.act_window">
        <field name="name">Instrument Registry</field>
        <field name="res_model">hvac.instrument</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_valid': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first instrument</p>
            <p>Track all measuring instruments, their calibration status, and certificate history.</p>
        </field>
    </record>

    <!-- ═══ Calibration Records ═══ -->
    <record id="view_hvac_calibration_form" model="ir.ui.view">
        <field name="name">hvac.calibration.form</field>
        <field name="model">hvac.calibration</field>
        <field name="arch" type="xml">
            <form string="Calibration Record">
                <sheet>
                    <div class="oe_title">
                        <label class="o_form_label" for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Calibration Details">
                            <field name="instrument_id"/>
                            <field name="calibration_date"/>
                            <field name="valid_until"/>
                            <field name="state" readonly="1" widget="badge"
                                   decoration-success="state == 'active'"
                                   decoration-muted="state == 'expired'"/>
                        </group>
                        <group string="Laboratory">
                            <field name="calibrated_by"/>
                            <field name="lab_accreditation_no"/>
                            <field name="reference_standard"/>
                            <field name="traceability"/>
                            <field name="calibration_method"/>
                        </group>
                    </group>
                    <group string="Result">
                        <group>
                            <field name="result" widget="radio"/>
                            <field name="error_found"/>
                            <field name="correction_factor"/>
                        </group>
                        <group>
                            <field name="certificate" filename="certificate_filename" widget="binary" string="Upload Certificate (PDF)"/>
                            <field name="certificate_filename" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="remarks"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hvac_calibration_list" model="ir.ui.view">
        <field name="name">hvac.calibration.list</field>
        <field name="model">hvac.calibration</field>
        <field name="arch" type="xml">
            <list string="Calibration Records"
                  decoration-muted="state == 'expired'"
                  decoration-success="state == 'active'">
                <field name="name" string="Certificate No."/>
                <field name="instrument_id"/>
                <field name="instrument_type"/>
                <field name="calibration_date"/>
                <field name="valid_until"/>
                <field name="calibrated_by"/>
                <field name="result" widget="badge"
                       decoration-success="result == 'pass'"
                       decoration-danger="result == 'fail'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="action_hvac_calibration" model="ir.actions.act_window">
        <field name="name">Calibration Records</field>
        <field name="res_model">hvac.calibration</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a calibration record</p>
            <p>Log calibration events and upload calibration certificates for each instrument.</p>
        </field>
    </record>

</data>
</odoo>
