      </t>
    </t>

    <tr>
      <td colspan="6" class="L">
        Result: - Meets / Does Not meet validation Acceptance Criteria as per Client Requirement.
      </td>
    </tr>
    <tr>
      <th colspan="3" style="text-align:center">Performed By</th>
      <th colspan="3" style="text-align:center">Checked By</th>
    </tr>
    <tr class="sr"><td colspan="3"></td><td colspan="3"></td></tr>
    <tr>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
    </tr>
    <tr><td colspan="6" class="ref">F/VL/001/03-02</td></tr>
  </table>

</div><!-- end Annexure III -->


<!-- ╔═══════════════════════════════════════════════════════╗ -->
<!-- ║  ANNEXURE IV — CFM/CMH Measurement and ACPH (SI)    ║ -->
<!--   Columns: Room | Filter | CFM | CMH(×1.7) | Total CMH | Room Vol (m³) | ACPH -->
<!-- ╚═══════════════════════════════════════════════════════╝ -->
<div class="pg pgbrk" t-if="o.vl001_subtype in ('both', 'cfm')">

  <table class="hdr">
    <tr>
      <td width="27%"><span class="mbox">MASTER COPY</span></td>
      <td width="46%" class="subtitle">CFM/ CMH Measurement &amp; ACPH</td>
      <td width="27%" class="mcell">
        <span class="mu">&#956;</span> <strong>MICRON</strong><br/>
        Rep. SOP No. MHPL/VL/001<br/>
        Page 1 of 1
      </td>
    </tr>
  </table>
  <div class="atitle">Annexure IV</div>

  <table class="ft">
    <tr><td colspan="7" class="sec-hdr">CFM/ CMH MEASUREMENT &amp; ACPH</td></tr>

    <tr>
      <td colspan="4" class="L">Client Name&#160;&#160;:-&#160;&#160;<t t-esc="o.partner_id.name or ''"/></td>
      <td colspan="3" class="L">Date: -&#160;&#160;
        <t t-if="o.test_date"><t t-esc="o.test_date.strftime('%d/%m/%Y')"/></t>
      </td>
    </tr>
    <tr>
      <td colspan="7" class="L" style="height:26px">
        AHU &amp; No.&#160;&#160;:-&#160;<t t-esc="o.ahu_tag or ''"/>
        <br/>&#160;
      </td>
    </tr>

    <tr>
      <th colspan="2">INSTRUMENT USED</th>
      <th colspan="3">CALIBRATION DATE</th>
      <th colspan="2">CALIBRATION DUE DATE</th>
    </tr>
    <tr style="height:44px">
      <td colspan="2" class="inst-td">
        Instrument.&#160;&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.name"/></t><br/>
        Model No.&#160;&#160;&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.model_no or ''"/></t><br/>
        Sr.No.&#160;&#160;&#160;&#160;&#160;&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.serial_no or ''"/></t>
      </td>
      <td colspan="3" class="C">
        <t t-if="ifh and ifh1.last_calibration_date">
          <t t-esc="ifh1.last_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
      <td colspan="2" class="C">
        <t t-if="ifh and ifh1.next_calibration_date">
          <t t-esc="ifh1.next_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
    </tr>

    <tr>
      <th style="width:20%">Room Name &amp; No.</th>
      <th style="width:13%">Filter ID</th>
      <th style="width:12%">CFM</th>
      <th style="width:15%">CMH<br/>(CFM&#215;1.7)</th>
      <th style="width:13%">Total CMH<br/>(Room)</th>
      <th style="width:14%">Room Vol.<br/>(m&#179;)</th>
      <th style="width:13%">ACPH</th>
    </tr>

    <!-- Data rows — SI units view -->
    <t t-foreach="o.vl001_line_ids" t-as="line">
    <t t-set="total_room_cmh"
       t-value="sum(o.vl001_line_ids.filtered(lambda l: l.room_name == line.room_name).mapped('cmh'))"/>
    <t t-set="room_acph_m3"
       t-value="round(total_room_cmh / line.room_vol_m3, 1) if line.room_vol_m3 else 0"/>
    <tr class="dr">
      <td class="L"><t t-esc="line.room_name or ''"/></td>
      <td class="C"><t t-esc="line.filter_id or ''"/></td>
      <td class="C"><t t-if="line.cfm"><t t-esc="'%.0f' % line.cfm"/></t></td>
      <td class="C"><t t-if="line.cmh"><t t-esc="'%.0f' % line.cmh"/></t></td>
      <td class="C"><t t-if="total_room_cmh"><t t-esc="'%.0f' % total_room_cmh"/></t></td>
      <td class="C"><t t-if="line.room_vol_m3"><t t-esc="'%.2f' % line.room_vol_m3"/></t></td>
      <td class="C">
        <t t-if="room_acph_m3"><t t-esc="'%.1f' % room_acph_m3"/></t>
      </td>
    </tr>
    </t>

    <!-- Pad -->
    <t t-if="n_lines &lt; MIN_ROWS">
      <t t-foreach="range(MIN_ROWS - n_lines)" t-as="r">
      <tr class="dr"><td></td><td></td><td></td><td></td><td></td><td></td><td></td></tr>
      </t>
    </t>

    <tr>
      <td colspan="7" class="L">
        Result: - Meets / Does Not meet validation Acceptance Criteria As per Client Requirement.
      </td>
    </tr>
    <tr>
      <th colspan="3" style="text-align:center">Performed By</th>
      <th colspan="4" style="text-align:center">Checked By</th>
    </tr>
    <tr class="sr"><td colspan="3"></td><td colspan="4"></td></tr>
    <tr>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
      <td colspan="4" style="text-align:center">Sign &amp; Date</td>
    </tr>
    <tr><td colspan="7" class="ref">F/VL/001/04-02</td></tr>
  </table>

</div><!-- end Annexure IV -->


