    <tr>
      <th colspan="2">INSTRUMENT USED</th>
      <th colspan="2">CALIBRATION DATE</th>
      <th colspan="2">CALIBRATION DUE DATE</th>
    </tr>
    <tr style="height:44px">
      <td colspan="2" class="inst-td">
        Instrument.&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.name"/></t><br/>
        Model No.&#160;&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.model_no or ''"/></t><br/>
        Sr. No.&#160;&#160;&#160;&#160;:-&#160;<t t-if="ifh"><t t-esc="ifh1.serial_no or ''"/></t>
      </td>
      <td colspan="2" class="C">
        <t t-if="ifh and ifh1.last_calibration_date">
          <t t-esc="ifh1.last_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
      <td colspan="2" class="C">
        <t t-if="ifh and ifh1.next_calibration_date">
          <t t-esc="ifh1.next_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
    </tr>

    <tr>
      <th style="width:28%">Room Name &amp; No.</th>
      <th style="width:16%">Filter ID</th>
      <th style="width:14%">CFM</th>
      <th style="width:14%">Total CFM<br/>(Room)</th>
      <th style="width:14%">Room Vol.<br/>(Ft&#179;)</th>
      <th style="width:14%">ACPH</th>
    </tr>

    <!-- Data rows — CFM-focused view -->
    <t t-foreach="o.vl001_line_ids" t-as="line">
    <tr class="dr">
      <td class="L"><t t-esc="line.room_name or ''"/></td>
      <td class="C"><t t-esc="line.filter_id or ''"/></td>
      <td class="C"><t t-if="line.cfm"><t t-esc="'%.0f' % line.cfm"/></t></td>
      <td class="C">
        <t t-if="line.total_room_cfm"><t t-esc="'%.0f' % line.total_room_cfm"/></t>
      </td>
      <td class="C"><t t-if="line.room_vol_ft3"><t t-esc="'%.0f' % line.room_vol_ft3"/></t></td>
      <td class="C">
        <t t-if="line.acph">
          <t t-esc="'%.1f' % line.acph"/>&#160;
          <span t-attf-class="#{line.acph_result}">
            <t t-if="line.acph_result != 'na'">(<t t-esc="line.acph_result.upper()"/>)</t></span>
        </t>
      </td>
    </tr>
    </t>

    <!-- Pad -->
    <t t-if="n_lines &lt; MIN_ROWS">
      <t t-foreach="range(MIN_ROWS - n_lines)" t-as="r">
