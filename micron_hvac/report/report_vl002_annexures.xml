<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="report_vl002_annexures_document">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">

<style>
  @page { size: A4 portrait; margin: 8mm 10mm 6mm 10mm; }
  body { font-family: Arial, sans-serif; font-size: 8.5pt; color: #000; }
  .pg { width: 100%; box-sizing: border-box; }
  .pgbrk { page-break-after: always; }

  /* ── Page header ── */
  .hdr { width: 100%; border-collapse: collapse; margin-bottom: 2px; }
  .hdr td { padding: 0 2px; vertical-align: middle; }
  .mbox { display: inline-block; border: 2px solid #000; padding: 2px 10px; font-weight: bold; font-size: 9pt; }
  .mcell { text-align: right; line-height: 1.45; font-size: 8pt; }
  .mu { font-size: 20pt; font-weight: bold; font-style: italic; font-family: 'Times New Roman', serif; vertical-align: middle; }
  .subtitle { text-align: center; font-weight: bold; font-size: 8.5pt; }
  .atitle { text-align: center; font-weight: bold; font-size: 9.5pt; margin: 1px 0 3px 0; }

  /* ── Form table ── */
  .ft { width: 100%; border-collapse: collapse; }
  .ft th, .ft td { border: 1px solid #000; padding: 2px 3px; font-size: 7.8pt; vertical-align: middle; }
  .ft th { font-weight: bold; text-align: center; }
  .ft td.L { text-align: left; }
  .ft td.C { text-align: center; }
  .sec-hdr { font-size: 9pt; font-weight: bold; text-align: center; padding: 3px 4px; }
  .inst-td { text-align: left; line-height: 1.75; vertical-align: top; }
  .dr td { height: 22px; }   /* data row */
  .sr td { height: 55px; }   /* sign row */
  .ref { text-align: right; font-size: 7pt; border: none !important; }

  .pass { color: #1a7e3f; font-weight: bold; }
  .fail { color: #c0392b; font-weight: bold; }
</style>

<!-- Retrieve Aerosol Photometer and Pressure Gauge instruments -->
<t t-set="iapm" t-value="o.instrument_used_ids.filtered(lambda i: i.instrument_type == 'aerosol_photometer')"/>
<t t-set="iapm1" t-value="iapm[0] if iapm else o.env['hvac.instrument']"/>

<t t-set="ipg" t-value="o.instrument_used_ids.filtered(lambda i: i.instrument_type == 'pressure_gauge')"/>
<t t-set="ipg1" t-value="ipg[0] if ipg else o.env['hvac.instrument']"/>

<t t-set="MIN_ROWS" t-value="12"/>
<t t-set="n_lines" t-value="len(o.vl002_line_ids)"/>

<div class="pg">
  <table class="hdr">
    <tr>
      <td width="27%"><span class="mbox">MASTER COPY</span></td>
      <td width="46%" class="subtitle">HEPA Filter Integrity Test (PAO)</td>
      <td width="27%" class="mcell">
        <span class="mu">&#956;</span> <strong>MICRON</strong><br/>
        Rep. SOP No. MHPL/VL/002<br/>
        Page 1 of 1
      </td>
    </tr>
  </table>
  <div class="atitle">Annexure I</div>

  <table class="ft">
    <tr><td colspan="9" class="sec-hdr">HEPA FILTER INTEGRITY TEST (PAO)</td></tr>

    <!-- Client / Date / AHU -->
    <tr>
      <td colspan="5" class="L">Client Name: -&#160;&#160;<t t-esc="o.partner_id.name or ''"/></td>
      <td colspan="4" class="L">Date: -&#160;&#160;
        <t t-if="o.test_date"><t t-esc="o.test_date.strftime('%d/%m/%Y')"/></t>
      </td>
    </tr>
    <tr>
      <td colspan="5" class="L">AHU No.: -&#160;&#160;<t t-esc="o.ahu_tag or ''"/></td>
      <td colspan="4" class="L">Room Name &amp; No.: -&#160;&#160;<t t-esc="o.vl002_line_ids[0].room_name if o.vl002_line_ids else ''"/></td>
    </tr>

    <!-- Instrument Used Header -->
    <tr>
      <th colspan="3">INSTRUMENT USED</th>
      <th colspan="3">CALIBRATION DATE</th>
      <th colspan="3">CALIBRATION DUE DATE</th>
    </tr>
    <tr style="height:55px">
      <td colspan="3" class="inst-td" style="font-size:7.5pt;">
        <t t-if="iapm">
          <strong>Aerosol Photometer:</strong> <t t-esc="iapm1.name"/><br/>
          Model No.: <t t-esc="iapm1.model_no or ''"/>&#160;|&#160;Sr. No.: <t t-esc="iapm1.serial_no or ''"/><br/>
        </t>
        <t t-if="ipg">
          <strong>Pressure Gauge:</strong> <t t-esc="ipg1.name"/><br/>
          Model No.: <t t-esc="ipg1.model_no or ''"/>&#160;|&#160;Sr. No.: <t t-esc="ipg1.serial_no or ''"/>
        </t>
      </td>
      <td colspan="3" class="C" style="font-size:7.5pt;">
        <t t-if="iapm and iapm1.last_calibration_date">
          Photometer: <t t-esc="iapm1.last_calibration_date.strftime('%d/%m/%Y')"/><br/>
        </t>
        <t t-if="ipg and ipg1.last_calibration_date">
          Pressure Gauge: <t t-esc="ipg1.last_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
      <td colspan="3" class="C" style="font-size:7.5pt;">
        <t t-if="iapm and iapm1.next_calibration_date">
          Photometer: <t t-esc="iapm1.next_calibration_date.strftime('%d/%m/%Y')"/><br/>
        </t>
        <t t-if="ipg and ipg1.next_calibration_date">
          Pressure Gauge: <t t-esc="ipg1.next_calibration_date.strftime('%d/%m/%Y')"/>
        </t>
      </td>
    </tr>

    <!-- Column Headers -->
    <tr>
      <th style="width:5%">Sr. No.</th>
      <th style="width:18%">Room Name &amp; No.</th>
      <th style="width:13%">Filter No.</th>
      <th style="width:13%">Upstream Conc.<br/>(Before) (µg/L)</th>
      <th style="width:10%">Leakage (%)</th>
      <th style="width:13%">Upstream Conc.<br/>(After) (µg/L)</th>
      <th style="width:11%">Recovery (%)<br/>(85%-115%)</th>
      <th style="width:8%">Result</th>
      <th style="width:9%">Remarks</th>
    </tr>

    <!-- Data Rows -->
    <t t-foreach="o.vl002_line_ids" t-as="line">
      <tr class="dr">
        <td class="C"><t t-esc="line_index + 1"/></td>
        <td class="L"><t t-esc="line.room_name or ''"/></td>
        <td class="C"><t t-esc="line.filter_id or ''"/></td>
        <td class="C"><t t-esc="'%.1f' % line.upstream_before if line.upstream_before else ''"/></td>
        <td class="C"><t t-esc="'%.4f%%' % line.downstream_pct if line.downstream_pct else '0.000%'"/></td>
        <td class="C"><t t-esc="'%.1f' % line.upstream_after if line.upstream_after else ''"/></td>
        <td class="C"><t t-esc="'%.1f%%' % line.upstream_recovery_pct if line.upstream_recovery_pct else ''"/></td>
        <td class="C">
          <span t-att-class="line.pao_result">
            <t t-esc="line.pao_result.upper() if line.pao_result else ''"/>
          </span>
        </td>
        <td class="L"><t t-esc="line.remark or ''"/></td>
      </tr>
    </t>

    <!-- Pad Empty Rows -->
    <t t-if="n_lines &lt; MIN_ROWS">
      <t t-foreach="range(MIN_ROWS - n_lines)" t-as="r">
        <tr class="dr">
          <td class="C"><t t-esc="n_lines + r + 1"/></td>
          <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
        </tr>
      </t>
    </t>

    <!-- Acceptance / Reference -->
    <tr>
      <td colspan="9" class="L" style="font-size:7.5pt;">
        <strong>ACCEPTANCE CRITERIA :</strong> AS PER ISO 14644-3:2019 ( E ) LEAKAGE NMT 0.01%
      </td>
    </tr>
    <tr>
      <td colspan="9" class="L" style="font-size:7.5pt;">
        <strong>REFERENCE :</strong> AS PER PROTOCOL No. PSV/PRO/001
      </td>
    </tr>

    <!-- Signatures -->
    <tr>
      <th colspan="3" style="text-align:center">Performed By</th>
      <th colspan="3" style="text-align:center">Witnessed By</th>
      <th colspan="3" style="text-align:center">Reviewed By</th>
    </tr>
    <tr class="sr">
      <td colspan="3" class="C" style="vertical-align:bottom; padding-bottom:5px;">
        <t t-if="o.tech_signature">
          <img t-att-src="'data:image/png;base64,' + o.tech_signature.decode()" style="max-height:35px; max-width:140px;"/>
        </t>
      </td>
      <td colspan="3" class="C" style="vertical-align:bottom; padding-bottom:5px;">
        <t t-if="o.client_signature">
          <img t-att-src="'data:image/png;base64,' + o.client_signature.decode()" style="max-height:35px; max-width:140px;"/>
        </t>
      </td>
      <td colspan="3"></td>
    </tr>
    <tr>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
      <td colspan="3" style="text-align:center">Sign &amp; Date</td>
    </tr>
    <tr><td colspan="9" class="ref">F/VL/002/01-02</td></tr>
  </table>
</div>

</t>
</t>
</template>

</data>
</odoo>
