<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="report_vl005_annexures_document">
<t t-call="web.html_container">
<t t-foreach="docs" t-as="o">

<style>
  @page { size: A4 landscape; margin: 8mm 10mm 6mm 10mm; }
  body { font-family: Arial, sans-serif; font-size: 8.5pt; color: #000; }
  .pg { width: 100%; box-sizing: border-box; }
  .pgbrk { page-break-after: always; }

  /* ── Page header ── */
  .hdr { width: 100%; border-collapse: collapse; margin-bottom: 2px; }
  .hdr td { padding: 0 2px; vertical-align: middle; }
  .mbox { display: inline-block; border: 2px solid #000; padding: 2px 10px; font-weight: bold; font-size: 9pt; }
  .mcell { text-align: right; line-height: 1.45; font-size: 8pt; }
  .mu { font-size: 20pt; font-weight: bold; font-style: italic; font-family: 'Times New Roman', serif; vertical-align: middle; }
  .subtitle { text-align: center; font-weight: bold; font-size: 8.5pt; }
  .atitle { text-align: center; font-weight: bold; font-size: 9.5pt; margin: 1px 0 3px 0; }

  /* ── Form table ── */
  .ft { width: 100%; border-collapse: collapse; margin-bottom: 8px; }
  .ft th, .ft td { border: 1px solid #000; padding: 2px 3px; font-size: 7.8pt; vertical-align: middle; }
  .ft th { font-weight: bold; text-align: center; }
  .ft td.L { text-align: left; }
  .ft td.C { text-align: center; }
  .sec-hdr { font-size: 9pt; font-weight: bold; text-align: center; padding: 3px 4px; }
  .inst-td { text-align: left; line-height: 1.75; vertical-align: top; }
  .dr td { height: 22px; }   /* data row */
  .sr td { height: 50px; }   /* sign row */
  .ref { text-align: right; font-size: 7pt; border: none !important; }

  .pass { color: #1a7e3f; font-weight: bold; }
  .fail { color: #c0392b; font-weight: bold; }
</style>

<!-- Retrieve Data Logger instrument -->
<t t-set="itrh" t-value="o.instrument_used_ids.filtered(lambda i: i.instrument_type == 'temp_rh_logger')"/>
<t t-set="itrh1" t-value="itrh[0] if itrh else o.env['hvac.instrument']"/>

<t t-set="MIN_ROWS" t-value="8"/>
<t t-set="n_lines" t-value="len(o.vl005_line_ids)"/>

<div class="pg">
  <table class="hdr">
    <tr>
      <td width="27%"><span class="mbox">MASTER COPY</span></td>
      <td width="46%" class="subtitle">Temperature &amp; Relative Humidity Study</td>
      <td width="27%" class="mcell">
        <span class="mu">&#956;</span> <strong>MICRON</strong><br/>
        Rep. SOP No. MHPL/VL/005<br/>
        Page 1 of 1
      </td>
    </tr>
  </table>
  <div class="atitle">Annexure I</div>

  <table class="ft">
    <tr><td colspan="15" class="sec-hdr">TEMPERATURE &amp; RELATIVE HUMIDITY STUDY</td></tr>

    <!-- Client / Date / AHU -->
    <tr>
      <td colspan="8" class="L">Client Name: -&#160;&#160;<t t-esc="o.partner_id.name or ''"/></td>
      <td colspan="7" class="L">Date: -&#160;&#160;
        <t t-if="o.test_date"><t t-esc="o.test_date.strftime('%d/%m/%Y')"/></t>
      </td>
    </tr>
    <tr>
      <td colspan="8" class="L">AHU No.: -&#160;&#160;<t t-esc="o.ahu_tag or ''"/></td>
      <td colspan="7" class="L">Room Name &amp; No.: -&#160;&#160;<t t-esc="o.vl005_line_ids[0].room_name if o.vl005_line_ids else ''"/></td>
    </tr>

    <!-- Instrument details -->
    <tr>
      <th colspan="15">INSTRUMENT DETAILS</th>
    </tr>
    <tr style="height:44px;">
      <td colspan="5" class="inst-td" style="font-size:7.5pt;">
        Instrument Used: <t t-esc="itrh1.name or 'Temperature &amp; RH Data Logger'"/><br/>
        Make / Model: <t t-esc="itrh1.make or 'Testo'"/>&#160;/&#160;<t t-esc="itrh1.model_no or ''"/>
      </td>
      <td colspan="5" class="inst-td" style="font-size:7.5pt;">
        Sr. No.: <t t-esc="itrh1.serial_no or ''"/><br/>
        Measurement Range: <t t-esc="itrh1.range_description or '-20 to +70 °C | 0–100% RH'"/>
      </td>
      <td colspan="5" class="inst-td" style="font-size:7.5pt;">
        Calibration Date: <t t-if="itrh1.last_calibration_date"><t t-esc="itrh1.last_calibration_date.strftime('%d/%m/%Y')"/></t><br/>
        Valid Until: <t t-if="itrh1.next_calibration_date"><t t-esc="itrh1.next_calibration_date.strftime('%d/%m/%Y')"/></t>
      </td>
    </tr>

    <!-- Column Headers -->
    <tr>
      <th rowspan="2" style="width:4%">Sr. No.</th>
      <th rowspan="2" style="width:14%">Room Name &amp; No.</th>
      <th rowspan="2" style="width:8%">Logger ID</th>
      <th rowspan="2" style="width:16%">Position Description</th>
      <th colspan="4" style="width:20%">Temperature (°C)</th>
      <th colspan="4" style="width:20%">Relative Humidity (%RH)</th>
      <th colspan="2" style="width:10%">Results</th>
      <th rowspan="2" style="width:8%">Remarks</th>
    </tr>
    <tr>
      <th style="width:5%">Mean</th>
      <th style="width:5%">Min</th>
      <th style="width:5%">Max</th>
      <th style="width:5%">Range</th>
      <th style="width:5%">Mean</th>
      <th style="width:5%">Min</th>
      <th style="width:5%">Max</th>
      <th style="width:5%">Range</th>
      <th style="width:5%">T</th>
      <th style="width:5%">RH</th>
    </tr>

    <!-- Data Rows -->
    <t t-foreach="o.vl005_line_ids" t-as="line">
      <tr class="dr">
        <td class="C"><t t-esc="line_index + 1"/></td>
        <td class="L"><t t-esc="line.room_name or ''"/></td>
        <td class="C"><t t-esc="line.logger_id or ''"/></td>
        <td class="L"><t t-esc="line.position or ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.temp_mean if line.temp_mean else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.temp_min if line.temp_min else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.temp_max if line.temp_max else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.temp_range if line.temp_range else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.rh_mean if line.rh_mean else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.rh_min if line.rh_min else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.rh_max if line.rh_max else ''"/></td>
        <td class="C"><t t-esc="'%.2f' % line.rh_range if line.rh_range else ''"/></td>
        <td class="C">
          <span t-att-class="line.temp_result">
            <t t-esc="line.temp_result.upper() if line.temp_result else ''"/>
          </span>
        </td>
        <td class="C">
          <span t-att-class="line.rh_result">
            <t t-esc="line.rh_result.upper() if line.rh_result else ''"/>
          </span>
        </td>
        <td class="L"><t t-esc="line.remark or ''"/></td>
      </tr>
    </t>

    <!-- Pad Empty Rows -->
    <t t-if="n_lines &lt; MIN_ROWS">
      <t t-foreach="range(MIN_ROWS - n_lines)" t-as="r">
        <tr class="dr">
          <td class="C"><t t-esc="n_lines + r + 1"/></td>
          <td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td><td></td>
        </tr>
      </t>
    </t>

    <!-- Limits / References -->
    <tr>
      <td colspan="15" class="L" style="font-size:7.5pt;">
        <strong>ACCEPTANCE LIMITS :</strong> TEMPERATURE: 18.0°C TO 27.0°C | RELATIVE HUMIDITY: 30.0% TO 65.0% RH | LOGGER TEMPERATURE VARIATION: NMT 2.0°C | LOGGER RH VARIATION: NMT 5.0%
      </td>
    </tr>
    <tr>
      <td colspan="15" class="L" style="font-size:7.5pt;">
        <strong>REFERENCE :</strong> WHO TRS 986 / EU GMP ANNEX 1 / SCHEDULE M (REVISED) 2023
      </td>
    </tr>

    <!-- Signatures -->
    <tr>
      <th colspan="5" style="text-align:center">Performed By</th>
      <th colspan="5" style="text-align:center">Witnessed By</th>
      <th colspan="5" style="text-align:center">Reviewed By</th>
    </tr>
    <tr class="sr">
      <td colspan="5" class="C" style="vertical-align:bottom; padding-bottom:5px;">
        <t t-if="o.tech_signature">
          <img t-att-src="'data:image/png;base64,' + o.tech_signature.decode()" style="max-height:35px; max-width:140px;"/>
        </t>
      </td>
      <td colspan="5" class="C" style="vertical-align:bottom; padding-bottom:5px;">
        <t t-if="o.client_signature">
          <img t-att-src="'data:image/png;base64,' + o.client_signature.decode()" style="max-height:35px; max-width:140px;"/>
        </t>
      </td>
      <td colspan="5"></td>
    </tr>
    <tr>
      <td colspan="5" style="text-align:center">Sign &amp; Date</td>
      <td colspan="5" style="text-align:center">Sign &amp; Date</td>
      <td colspan="5" style="text-align:center">Sign &amp; Date</td>
    </tr>
    <tr><td colspan="15" class="ref">F/VL/005/01-02</td></tr>
  </table>
</div>

</t>
</t>
</template>

</data>
</odoo>
